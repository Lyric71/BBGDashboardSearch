---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import { readFileSync, readdirSync, existsSync } from 'fs';
import { join } from 'path';

const reportsDir = join(process.cwd(), '..', 'data', 'raw');
const files = existsSync(reportsDir)
  ? readdirSync(reportsDir).filter(f => f.startsWith('keywords') && f.endsWith('.md'))
  : [];

const reports = files.map(f => ({
  name: f.replace('.md', '').replace(/keywords_/,'').replace(/_/g, ' '),
  file: f,
  html: marked(readFileSync(join(reportsDir, f), 'utf8')),
}));
---
<Layout title="Keywords">
  <div class="mb-8">
    <a href="/" class="text-sm text-gray-400 hover:text-gray-600 mb-4 inline-block">&larr; Dashboard</a>
    <h1 class="text-3xl font-bold mb-2" style="color: var(--bbg-blue)">🔍 Keywords</h1>
    <p class="text-gray-500">Master keyword list and opportunity mapping.</p>
  </div>

  {reports.length === 0 ? (
    <div class="rounded-3xl border border-dashed border-gray-200 p-12 text-center text-gray-400">
      No keyword reports yet. Save results to <code>data/raw/keywords_*.md</code>
    </div>
  ) : (
    reports.map(r => (
      <div class="mb-8 rounded-3xl border border-gray-100 overflow-hidden" style="box-shadow: 10px 5px 10px rgba(0,0,0,0.05)">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between" style="background: var(--bbg-gray-light)">
          <h2 class="font-semibold capitalize">{r.name}</h2>
          <span class="text-xs text-gray-400">{r.file}</span>
        </div>
        <div class="p-6 prose max-w-none overflow-x-auto" set:html={r.html} />
      </div>
    ))
  )}
</Layout>
