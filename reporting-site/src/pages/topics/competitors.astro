---
import Layout from '../../layouts/Layout.astro';
import ReportList from '../../components/ReportList.astro';
---
<Layout title="Competitors">
  <div class="mb-8">
    <a href="/" class="text-sm text-gray-400 hover:text-gray-600 mb-4 inline-block">&larr; Dashboard</a>
    <h1 class="text-3xl font-bold mb-2" style="color: var(--bbg-red)">⚔️ Competitors</h1>
    <p class="text-gray-500">SERP rank tracking — BBG vs top 27 competitors across all keyword categories.</p>
  </div>
  <ReportList dir="reports/competitors" />
</Layout>
