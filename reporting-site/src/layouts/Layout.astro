---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
const nav = [
  { label: 'Dashboard', href: '/' },
  { label: 'Keywords', href: '/topics/keywords' },
  { label: 'Competitors', href: '/topics/competitors' },
  { label: 'Ads', href: '/topics/ads' },
  { label: 'Content', href: '/topics/content' },
  { label: '🇬🇧 EN', href: '/lang/en' },
  { label: '🇫🇷 FR', href: '/lang/fr' },
];
const current = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — BBG SEO & Ads</title>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header -->
  <header class="border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-3 h-8 rounded" style="background: var(--bbg-red)"></div>
        <div>
          <div class="font-bold text-sm tracking-wide uppercase" style="color: var(--bbg-gray-dark)">Beyond Border Group</div>
          <div class="text-xs" style="color: var(--bbg-gray-muted)">SEO & Ads Intelligence</div>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <nav class="flex items-center gap-1">
          {nav.map(item => (
            <a
              href={item.href}
              class={`px-3 py-1.5 rounded text-sm font-medium transition-colors ${
                current === item.href
                  ? 'text-white'
                  : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'
              }`}
              style={current === item.href ? 'background: var(--bbg-gray-dark)' : ''}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <a href="https://beyondbordergroup.com" target="_blank" rel="noopener">
          <img
            src="https://beyondbordergroup.com/wp-content/uploads/2024/11/Logo-Beyond-Litho.png"
            alt="Beyond Border Group"
            class="h-8 w-auto"
          />
        </a>
      </div>
    </div>
  </header>

  <!-- Page -->
  <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-10">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-200 mt-auto">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center text-xs" style="color: var(--bbg-gray-muted)">
      <span>beyondbordergroup.com</span>
      <span>Updated {new Date().toLocaleDateString('en-CA')}</span>
    </div>
  </footer>
</body>
</html>
